# Plantilla de configuración. Copia este archivo como .env y pon tu clave real.
#   cp .env.example .env
# Obtén la clave en Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Fallback TEMPORAL de entrenamiento (NVIDIA NIM) ──────────────────────────
# Clave de https://build.nvidia.com (deja vacío para desactivar el fallback).
NVIDIA_API_KEY=
# true SOLO en entrenamiento: ante un 429 de Gemini, prueba NIM antes de detener.
ARIA_TRAINING_MODE=false
